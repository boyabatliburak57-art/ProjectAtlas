{
  "name": "project-atlas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "22.14.0",
    "pnpm": "9.15.4"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.16",
      "sharp": "0.35.3"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "chaos:staging": "node scripts/operations/run-staging-chaos.mjs",
    "alert:validate": "sh scripts/production/validate-alert-rules.sh",
    "config:check": "node scripts/production/check-config-drift.mjs",
    "deploy:validate": "node scripts/production/validate-artifacts.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gameday:staging-profile": "node scripts/production/run-staging-gameday.mjs",
    "lint": "turbo run lint",
    "observability:validate": "node scripts/production/validate-observability.mjs",
    "recovery:validate": "node scripts/recovery/validate-recovery-controls.mjs",
    "recovery:restore-drill": "node scripts/recovery/run-restore-drill.mjs",
    "recovery:object-drill": "pnpm --filter @atlas/worker exec tsx src/recovery/object-restore-drill.ts",
    "recovery:redis-drill": "node scripts/recovery/run-redis-loss-drill.mjs",
    "security:validate": "node scripts/security/validate-security-controls.mjs",
    "license:check": "node scripts/security/check-licenses.mjs",
    "dast:staging": "node scripts/security/run-staging-dast.mjs",
    "slo:report": "node scripts/production/generate-slo-report.mjs observability/slo/sample-window.json reports/slo-error-budget.md",
    "synthetic:self-test": "node scripts/production/run-staging-synthetics.mjs --self-test",
    "perf:scanner": "bash scripts/run-scanner-performance.sh",
    "perf:alerts": "bash scripts/run-alerts-watchlists-performance.sh",
    "perf:backtest": "bash scripts/run-backtest-performance.sh",
    "perf:portfolio": "bash scripts/run-portfolio-performance.sh",
    "perf:market": "bash scripts/run-market-intelligence-performance.sh",
    "perf:production": "node scripts/operations/run-production-load.mjs",
    "perf:market:regression": "bash scripts/run-market-intelligence-regression.sh",
    "preinstall": "node scripts/check-toolchain-versions.mjs --node-only",
    "resilience:validate": "node scripts/operations/validate-resilience-contract.mjs",
    "secret:scan": "bash scripts/secret-scan.sh --all",
    "secret:scan:test": "bash scripts/test-secret-scan.sh",
    "workflow:lint": "sh scripts/production/lint-workflows.sh",
    "test": "turbo run test",
    "test:adr-validator": "node --test scripts/validate-adr-identifiers.test.mjs",
    "test:version-check": "node --test scripts/check-toolchain-versions.test.mjs",
    "test:resilience": "node --test scripts/operations/resilience-core.test.mjs",
    "validate:adr": "node scripts/validate-adr-identifiers.mjs",
    "version:check": "node scripts/check-toolchain-versions.mjs",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "prettier": "3.8.1",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0"
  }
}
