ATLAS_ENV=production
NODE_ENV=production
CONFIG_SCHEMA_VERSION=1
API_CORS_ORIGIN=https://atlas.example
API_DEBUG=false
AUTH_SESSION_HMAC_KEY=${ATLAS_PRODUCTION_AUTH_SESSION_HMAC_KEY_FROM_SECRET_MANAGER}
SECURITY_RATE_LIMIT_ENABLED=true
DATABASE_URL=${ATLAS_PRODUCTION_DATABASE_URL_FROM_SECRET_MANAGER}
REDIS_URL=${ATLAS_PRODUCTION_REDIS_URL_FROM_SECRET_MANAGER}
HEALTH_CHECK_DATABASE=true
METRICS_BEARER_TOKEN=${ATLAS_METRICS_BEARER_TOKEN}
OBJECT_STORAGE_ENDPOINT=https://object-storage.example
OBJECT_STORAGE_BUCKET=atlas-production
OBJECT_STORAGE_ACCESS_KEY_ID=${ATLAS_PRODUCTION_OBJECT_ACCESS_KEY_FROM_SECRET_MANAGER}
OBJECT_STORAGE_SECRET_ACCESS_KEY=${ATLAS_PRODUCTION_OBJECT_SECRET_KEY_FROM_SECRET_MANAGER}
NEXT_PUBLIC_API_URL=https://api.atlas.example/api/v1
RELEASE_VERSION=${ATLAS_RELEASE_VERSION}
TELEMETRY_POLICY_VERSION=telemetry-v1
RELEASE_COMMIT_SHA=${ATLAS_RELEASE_COMMIT_SHA}
WORKER_ROLE=${ATLAS_WORKER_ROLE}
WORKER_HEALTH_FILE=/tmp/atlas-worker-ready
WORKER_DEBUG=false
