      "title": "Error budget remaining",
      "type": "gauge",
      "targets": [
        { "expr": "atlas_slo_error_budget_remaining_ratio", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Rollout readiness",
      "type": "stat",
      "targets": [
        { "expr": "min by (release) (atlas_workload_ready)", "refId": "A" }
      ]
    }
  ],
